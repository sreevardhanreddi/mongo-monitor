APP_NAME=MongoDB Monitoring

# Fernet key for encrypting stored MongoDB connection strings.
# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to disable encryption (connection strings stored as plaintext).
ENCRYPTION_KEY=EhAESYpk_XzzWT6vsf10GjKUduLBsbmXNi3k62jDM2U=

# Set AUTH_ENABLED=true to protect the whole app with HTTP Basic auth.
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

METADATA_MONGO_URI=mongodb://metadata-mongodb:27017
METADATA_MONGO_DB=mongodb_monitoring

REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
MONITOR_INTERVAL_SECONDS=30
STORAGE_STATS_INTERVAL_SECONDS=300
